# Environment Configuration Example
# Copy this to .env and modify as needed

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest
OLLAMA_TIMEOUT=300

# Model Parameters
TEMPERATURE=0.7
TOP_P=0.9

# Application Settings
DEBUG=False
LOG_LEVEL=INFO

